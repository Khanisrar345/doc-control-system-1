</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
const COLORS=['#0d9488','#6366f1','#d97706','#dc2626','#7c3aed','#0891b2','#16a34a','#f43f5e','#84cc16','#0ea5e9'];
function exportCSV(){
  const table=document.getElementById('registerTable'); if(!table) return alert('No table');
  let csv=[]; for(const row of table.rows){csv.push([...row.cells].map(c=>'"'+c.innerText.replace(/"/g,'""').trim()+'"').join(','));}
  const a=document.createElement('a'); a.href=URL.createObjectURL(new Blob([csv.join('\n')],{type:'text/csv'}));
  a.download='register.csv'; a.click();
}
function openReset(id,name){
  document.getElementById('resetId').value=id;
  document.getElementById('resetName').textContent='Reset password for '+name;
  new bootstrap.Modal(document.getElementById('resetModal')).show();
}
async function importExcel(){
  const f=document.getElementById('excelFile')?.files?.[0];
  if(!f) return alert('Choose an Excel file');
  const fd=new FormData(); fd.append('excel_file',f);
  const el=document.getElementById('importResult');
  if(el) el.textContent='Importing…';
  try{
    const r=await fetch('/import-excel',{method:'POST',body:fd});
    const d=await r.json();
    if(d.error){ if(el) el.textContent=d.error; alert(d.error); }
    else { if(el) el.textContent=`Imported ${d.imported}, skipped ${d.skipped}`; setTimeout(()=>location.reload(),1200); }
  }catch(e){ alert(e.message); }
}
<% if(page==='dashboard'){ %>
(async()=>{
  try{
    const d=await (await fetch('/api/stats')).json();
    const tL=Object.keys(d.by_type||{}), tD=tL.map(k=>d.by_type[k]);
    const sL=Object.keys(d.by_status||{}), sD=sL.map(k=>d.by_status[k]);
    const dL=Object.keys(d.by_discipline||{}), dD=dL.map(k=>d.by_discipline[k]);
    const mL=(d.monthly_trend||[]).map(x=>x.label), mD=(d.monthly_trend||[]).map(x=>x.count);
    if(document.getElementById('chartType')&&tL.length) new Chart(document.getElementById('chartType'),{type:'bar',data:{labels:tL,datasets:[{data:tD,backgroundColor:tL.map((_,i)=>COLORS[i%COLORS.length]),borderRadius:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}});
    if(document.getElementById('chartStatus')&&sL.length) new Chart(document.getElementById('chartStatus'),{type:'doughnut',data:{labels:sL,datasets:[{data:sD,backgroundColor:sL.map((_,i)=>COLORS[i%COLORS.length]),borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:11}}}}}});
    if(document.getElementById('chartDisc')&&dL.length) new Chart(document.getElementById('chartDisc'),{type:'pie',data:{labels:dL,datasets:[{data:dD,backgroundColor:dL.map((_,i)=>COLORS[i%COLORS.length])}]},options:{responsive:true,maintainAspectRatio:false}});
    if(document.getElementById('chartMonth')) new Chart(document.getElementById('chartMonth'),{type:'line',data:{labels:mL.length?mL:['—'],datasets:[{data:mD.length?mD:[0],borderColor:'#0d9488',backgroundColor:'rgba(13,148,136,.15)',fill:true,tension:.35}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}});
  }catch(e){console.error(e)}
})();
<% } %>
</script>
</body>
</html>
