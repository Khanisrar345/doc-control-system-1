          <% if(canEditDocs){ %><td class="no-print">
            <a href="/app?page=edit_document&id=<%= d._id %>" style="color:var(--accent)"><i class="fa-solid fa-pen"></i></a>
            <a href="/app?page=document_register&delete=1&table=documents&id=<%= d._id %>" onclick="return confirm('Delete <%= d.doc_number %>?')" style="color:#dc2626;margin-left:8px"><i class="fa-solid fa-trash"></i></a>
          </td><% } %>
