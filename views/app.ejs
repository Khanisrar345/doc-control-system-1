            <div class="col-md-6"><label class="label">Doc Number</label><input class="inp" name="doc_number" value="<%= isEdit?doc.doc_number:'' %>" placeholder="Auto if blank"/></div>
            <div class="col-md-6"><label class="label">Type *</label><input class="inp" name="type" list="typeList" value="<%= isEdit?doc.type:'' %>" required/><datalist id="typeList"><% (doc_types||[]).forEach(t=>{ %><option value="<%= t %>"><% }) %></datalist></div>
            <div class="col-md-12"><label class="label">Title *</label><input class="inp" name="title" value="<%= isEdit?doc.title:'' %>" required/></div>
            <div class="col-md-4"><label class="label">Rev</label><input class="inp" name="rev" value="<%= isEdit?doc.rev:'A' %>"/></div>
            <div class="col-md-4"><label class="label">Status</label><input class="inp" name="status" list="statusList" value="<%= isEdit?doc.status:'Open' %>"/><datalist id="statusList"><% (statuses||[]).forEach(s=>{ %><option value="<%= s %>"><% }) %></datalist></div>
            <div class="col-md-4"><label class="label">Discipline</label><input class="inp" name="discipline" list="discList" value="<%= isEdit?doc.discipline:'' %>"/><datalist id="discList"><% (disciplines||[]).forEach(d=>{ %><option value="<%= d %>"><% }) %></datalist></div>
            <div class="col-md-4"><label class="label">Area</label><input class="inp" name="area" value="<%= isEdit?doc.area:'' %>"/></div>
            <div class="col-md-4"><label class="label">Package</label><input class="inp" name="package" value="<%= isEdit?doc.package:'' %>"/></div>
            <div class="col-md-4"><label class="label">Contractor</label><input class="inp" name="contractor" list="contrList" value="<%= isEdit?doc.contractor:'' %>"/><datalist id="contrList"><% (contractors||[]).forEach(c=>{ %><option value="<%= c %>"><% }) %></datalist></div>
            <div class="col-md-4"><label class="label">Consultant</label><input class="inp" name="consultant" value="<%= isEdit?doc.consultant:'' %>"/></div>
            <div class="col-md-4"><label class="label">Issue Date</label><input class="inp" type="date" name="issue_date" value="<%= isEdit&&doc.issue_date?new Date(doc.issue_date).toISOString().slice(0,10):'' %>"/></div>
            <div class="col-md-4"><label class="label">Due Date</label><input class="inp" type="date" name="due_date" value="<%= isEdit&&doc.due_date?new Date(doc.due_date).toISOString().slice(0,10):'' %>"/></div>
            <div class="col-md-4"><label class="label">Response Date</label><input class="inp" type="date" name="response_date" value="<%= isEdit&&doc.response_date?new Date(doc.response_date).toISOString().slice(0,10):'' %>"/></div>
            <div class="col-md-4"><label class="label">Submitted By</label><input class="inp" name="submitted_by" value="<%= isEdit?doc.submitted_by:'' %>"/></div>
            <div class="col-md-4"><label class="label">Reviewer</label><input class="inp" name="reviewer" value="<%= isEdit?doc.reviewer:'' %>"/></div>
            <div class="col-md-4"><label class="label">Approver</label><input class="inp" name="approver" value="<%= isEdit?doc.approver:'' %>"/></div>
            <div class="col-12"><label class="label">Remarks</label><textarea class="inp" name="remarks" rows="3"><%= isEdit?doc.remarks:'' %></textarea></div>
            <% if(isEdit){ %><div class="col-12"><label class="label">Change Note</label><input class="inp" name="change_note"/></div><% } %>
