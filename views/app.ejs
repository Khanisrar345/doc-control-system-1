      <% }) %>
      <% if(!(documents||[]).length){ %><tr><td colspan="12" style="text-align:center;padding:28px;color:var(--muted)">No documents found</td></tr><% } %>
      </tbody></table></div></div>
    <% } %>
    <% if(page==='add_document'||page==='edit_document'){ const isEdit=page==='edit_document'&&doc; %>
      <div class="cardx">
        <div class="sec"><%= isEdit?'Edit Document':'Add Document' %></div>
