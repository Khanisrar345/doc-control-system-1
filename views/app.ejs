            <div class="col-md-4"><label class="label">Project Logo</label><input class="inp" type="file" name="project_logo" accept="image/*"/><% if(b.project_logo){ %><img src="/uploads/<%= b.project_logo %>" style="height:40px;margin-top:6px"/><% } %></div>
            <div class="col-md-6"><label class="label">Consultant Logo</label><input class="inp" type="file" name="consultant_logo" accept="image/*"/></div>
