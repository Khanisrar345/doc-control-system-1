            <div class="col-md-4"><label class="label">Company Logo</label><input class="inp" type="file" name="company_logo" accept="image/*"/><% if(b.company_logo){ %><img src="/uploads/<%= b.company_logo %>" style="height:40px;margin-top:6px"/><% } %></div>
