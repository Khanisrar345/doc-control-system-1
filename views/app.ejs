    <% if(page==='reports'){ %>
      <div class="no-print mb-3 d-flex gap-2"><button class="btnx" onclick="window.print()">Print Report</button><button class="btno" onclick="exportCSV()">Export CSV</button></div>
      <div class="row g-3 mb-3">
        <div class="col-6 col-md-3"><div class="kpi k-teal"><div class="lbl">Total</div><div class="val"><%= total_documents||0 %></div></div></div>
        <div class="col-6 col-md-3"><div class="kpi k-green"><div class="lbl">Approved</div><div class="val"><%= approved_count||0 %></div></div></div>
        <div class="col-6 col-md-3"><div class="kpi k-amber"><div class="lbl">Pending</div><div class="val"><%= pending_count||0 %></div></div></div>
        <div class="col-6 col-md-3"><div class="kpi k-red"><div class="lbl">Overdue</div><div class="val"><%= overdue_count||0 %></div></div></div>
      </div>
      <div class="cardx">
        <div class="sec">Overdue Documents</div>
        <div class="table-responsive"><table class="tbl" id="registerTable"><thead><tr><th>Doc No</th><th>Type</th><th>Title</th><th>Discipline</th><th>Due</th><th>Days</th></tr></thead><tbody>
        <% (overdue_docs||[]).forEach(d=>{ %>
          <tr><td><strong><%= d.doc_number %></strong></td><td><span class="chip"><%= d.type %></span></td><td><%= d.title %></td><td><%= d.discipline||'—' %></td><td><%= fmt(d.due_date) %></td><td style="color:#dc2626;font-weight:800"><%= d.days_open %></td></tr>
