<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sign In — Enterprise Document Control</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;
background:linear-gradient(145deg,#0f172a 0%,#0d5f5f 55%,#134e4a 100%);padding:20px}
.login-card{background:#fff;border-radius:20px;padding:48px 40px;max-width:420px;width:100%;
box-shadow:0 25px 60px rgba(0,0,0,.35)}
.logo-box{width:64px;height:64px;border-radius:14px;background:linear-gradient(135deg,#0d5f5f,#23a6a6);
display:flex;align-items:center;justify-content:center;margin:0 auto 18px;
font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:#fff}
h1{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:#0f172a;text-align:center}
.sub{font-size:13px;color:#94a3b8;text-align:center;margin:6px 0 28px}
.form-label{font-size:12px;font-weight:600;color:#334155;margin-bottom:6px}
.form-control{background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;padding:12px 14px;font-size:14px}
.form-control:focus{border-color:#1a7a7a;box-shadow:0 0 0 3px rgba(26,122,122,.15);background:#fff}
.btn-signin{background:#0d5f5f;color:#fff;border:none;border-radius:10px;padding:13px;width:100%;
font-weight:600;font-size:15px;margin-top:8px;cursor:pointer}
.btn-signin:hover{background:#0a4a4a}
.alert{border-radius:10px;font-size:13px}
.footer{text-align:center;margin-top:28px;font-size:11px;color:#94a3b8}
.forgot{display:block;text-align:right;font-size:12px;color:#64748b;margin-top:8px;text-decoration:none}
</style>
</head>
<body>
<div class="login-card">
  <div class="logo-box">EDMS</div>
  <h1>Document Control System</h1>
  <p class="sub">Enterprise Construction EDMS</p>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <form method="POST" action="/login" autocomplete="off">
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-control" required autocomplete="username" placeholder="Enter your email"/>
    </div>
    <div class="mb-2">
      <label class="form-label">Password</label>
      <input type="password" name="password" class="form-control" required autocomplete="current-password" placeholder="Enter your password"/>
    </div>
    <a class="forgot" href="#" onclick="alert('Contact your Super Admin to reset your password.');return false;">Forgot password?</a>
    <button type="submit" class="btn-signin">Sign In</button>
  </form>
  <div class="footer">Secure session · Role-based access · No credentials displayed on this page</div>
</div>
</body>
</html>
